# Aura 应用配置文件
# 使用方式：复制本文件为 config/app.yaml，按实际环境填写值。
# 支持 ${ENV_VAR} 语法引用系统环境变量（适用于 CI/CD 和容器部署）。
#
# 多环境：通过 APP_ENV 选择配置文件，优先 config/app.${APP_ENV}.yaml，
# 不存在时回退到 config/app.yaml。文件修改后自动热更新，无需重启。

# ── 服务监听 ──────────────────────────────────────────────────────────────────
server:
  grpc_addr: ":5568"                 # gRPC 原生端口（内部服务间调用 / 高性能客户端）
  http_addr: ":8080"                 # HTTP REST 网关端口（前端 / 第三方 / Postman）
  read_header_timeout_secs: 10       # 读请求头超时，防 Slowloris 慢速攻击
  shutdown_timeout_secs: 10          # 优雅关闭等待超时

  # HTTP CORS 策略（仅影响 http_addr）。
  # 生产环境请显式收敛 allowed_origins，不要保留默认的 "*"。
  # 注意：CORS 规范禁止 allowed_origins=["*"] 与 allow_credentials=true 同时使用，
  # 启动时会 fail-fast 拒绝这种组合。
  cors:
    allowed_origins: ["*"]
    allowed_methods: ["GET", "POST", "PATCH", "DELETE", "OPTIONS"]
    allowed_headers: ["Content-Type", "Authorization"]
    allow_credentials: false

# ── JWT ───────────────────────────────────────────────────────────────────────
jwt:
  # 生产环境务必通过环境变量注入，不要硬编码：
  # HS256 推荐使用至少 32 字节（256 bit）的强随机密钥，否则启动时会打印告警。
  secret: "${JWT_SECRET}"
  issuer: "aura"
  ttl_hours: 2                       # token 有效期（小时）

# ── HMAC 请求签名鉴权（TC-HMAC-SHA256，面向 OpenAPI / 机器对机器调用）─────────
# 外层 HMAC 验"信封"（调用方身份 + body 完整性 + 防重放），算法见《JWT + HMAC 双层鉴权方案》。
# 调用方与本服务预共享 app_id / secret，请求时携带（独立头，不占用 Authorization）：
#   X-Auth-AppId / X-Auth-Timestamp(Unix 秒) / X-Auth-Nonce
#   X-Auth-Sign: TC-HMAC-SHA256 Credential=<app_id>,Signature=<大写HEX>
# 规范请求串 = TC-HMAC-SHA256\nMETHOD\nPATH\nCANONICAL_QUERY\nHEX(SHA256(BODY))\nTIMESTAMP\nNONCE
# 签名 = ToUpper(HEX(HMAC_SHA256(secret, 规范请求串)))；详见 pkg/hmac。
# Authorization: Bearer 仍留给 JWT，两层鉴权互不干扰。
# enabled=false（默认）时 HTTP 网关不挂签名中间件，对现有 JWT 流程零影响。
# 防重放需要 Redis（SETNX nonce 去重）；Redis 未启用时退化为仅时间窗。
hmac:
  enabled: false
  skew_secs: 300                     # 请求时间戳与服务端时钟最大偏移（秒），防重放
  protected_prefixes: []             # 仅对命中前缀的路由验签（如 ["/v1/openapi/"]）；留空=保护全部
  keys:                              # enabled=true 时至少配置一条；secret 建议用环境变量注入
    - app_id: "101"
      secret: "${HMAC_SECRET_101}"

# ── 日志 ──────────────────────────────────────────────────────────────────────
# level / format 热更生效；output 与 file.* 属【需重启】。
# output=stdout（默认）适合容器/云原生（滚动归档交给采集侧 Fluent Bit / Loki）；
# output=file / both 时启用进程内文件滚动（lumberjack）：单文件超 max_size_mb 自动切割，
# 并按 max_backups（个数）与 max_age_days（天数）清理旧文件，防止日志无限膨胀占满磁盘。
log:
  level: "info"                      # debug | info | warn | error
  format: "text"                     # text | json
  output: "stdout"                   # stdout | file | both
  file:
    path: "logs/aura.log"            # 日志文件路径（output 含 file 时生效）
    max_size_mb: 100                 # 单文件最大体积（MB），超过即切割
    max_backups: 10                  # 最多保留的旧文件个数
    max_age_days: 30                 # 旧文件最长保留天数
    compress: true                   # 是否 gzip 压缩切割后的旧文件

# ── 限流（单机过载保护）──────────────────────────────────────────────────────
# 挂在 gRPC 入口拦截器上。由于 HTTP REST 经 grpc-gateway 同进程 loopback 转发到 gRPC，
# 这一道限流同时覆盖 gRPC 直连与 HTTP 两个入口（与 JWT 鉴权同款契约），HTTP 端无需重复挂。
# 被限流时 gRPC 返回 ResourceExhausted，网关自动映射为 HTTP 429。
# 这是「单实例」过载保护：多副本各自独立计数，整体容量 ≈ rps × 副本数。
# enabled / rps / burst 均热更生效，改 yaml 即时切换无需重启。
ratelimit:
  enabled: false                     # 是否启用过载保护（false 或 rps<=0 恒放行）
  rps: 0                             # 整机每秒允许的平均请求数（令牌产生速率）
  burst: 0                           # 突发桶容量（瞬时可同时通过的最大请求数）；<1 自动取 1

# ── 数据库 ────────────────────────────────────────────────────────────────────
database:
  enabled: false                     # 是否启用数据库（关闭则启动期不建连接池）
  driver: "mysql"                    # 数据库驱动：mysql | postgres
  # DSN 按 driver 填写：
  #   mysql:    user:pass@tcp(host:3306)/db?charset=utf8mb4&parseTime=true&loc=Local
  #   postgres: host=h user=u password=p dbname=d port=5432 sslmode=disable TimeZone=Asia/Shanghai
  dsn: "${DATABASE_DSN}"
  max_open_conns: 50
  max_idle_conns: 10
  conn_max_lifetime_secs: 1800

# ── Redis ─────────────────────────────────────────────────────────────────────
redis:
  enabled: false                     # 是否启用 Redis（关闭则启动期不建连接池）
  host: "127.0.0.1"
  port: 6379
  password: "${REDIS_PASSWORD}"
  db: 0
  pool_size: 10
  min_idle_conns: 2
  dial_timeout_secs: 5
  read_timeout_secs: 3
  write_timeout_secs: 3
  max_retries: 2

# ── 可观测性 ──────────────────────────────────────────────────────────────────
# metrics / health / pprof 统一挂在独立运维端口 admin_addr 上，与业务端口隔离，
# 仅在内网/受信网络暴露，切勿对公网开放。
observability:
  admin_addr: ":9090"                # 运维端口：承载 /metrics、/healthz、/readyz、/debug/pprof
  metrics:
    enabled: true                    # 暴露 Prometheus 拉取端点
    path: "/metrics"
  tracing:
    enabled: true                    # 关闭后日志将不再带 trace_id
    exporter: "none"                 # none（仅进程内，不上报）| otlp（上报到 collector）
    endpoint: "localhost:4317"       # exporter=otlp 时的 OTLP gRPC collector 地址
    insecure: true                   # 内网 collector 明文连接；生产建议 TLS
    sample_ratio: 1.0                # [0,1] 采样比例；高流量可调小（trace_id 仍始终生成）
  pprof:
    enabled: false                   # 性能剖析端点，默认关闭，仅排障时临时开启
